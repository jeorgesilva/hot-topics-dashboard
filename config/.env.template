# Copy this file to .env and fill in your values
# cp config/.env.template .env

# YouTube Data API v3 (https://console.cloud.google.com/apis)
YOUTUBE_API_KEY=

# GNews API (https://gnews.io/) — OR use NewsAPI instead
GNEWS_API_KEY=

# NewsAPI — REQUIRED for the scraper pipeline (https://newsapi.org/register)
NEWSAPI_KEY=

# SearXNG self-hosted instance for --broad-search mode; leave empty to use DuckDuckGo fallback
SEARXNG_URL=http://localhost:8080

# Optional: Telegram Bot for alerts (https://core.telegram.org/bots)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Domain trust — live scoring signals
# Google Safe Browsing v4 (https://console.cloud.google.com/apis/library/safebrowsing.googleapis.com)
GOOGLE_SAFE_BROWSING_KEY=
# OpenPageRank free tier (https://www.domcop.com/openpagerank/signup) — optional, improves domain scoring
OPEN_PAGE_RANK_KEY=
