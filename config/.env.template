# Copy this file to .env and fill in your values
# cp config/.env.template .env

# Reddit API (register at https://www.reddit.com/prefs/apps — script type)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=misinfo-dashboard/1.0

# YouTube Data API v3 (https://console.cloud.google.com/apis)
YOUTUBE_API_KEY=

# GNews API (https://gnews.io/) — OR use NewsAPI instead
GNEWS_API_KEY=

# Optional: NewsAPI (https://newsapi.org/)
# NEWSAPI_KEY=

# Optional: Telegram Bot for alerts (https://core.telegram.org/bots)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
