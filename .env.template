# Configuration template for Hot Topics Dashboard
# Copy this file to .env and fill in your credentials

# Optional: NewsAPI
# NEWSAPI_KEY=

# Optional: Telegram notifications
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: SearXNG instance for MBFC runtime lookup
# SEARXNG_URL=http://localhost:8080

# Domain trust — live scoring signals (optional, improves coverage of unknown domains)
# GOOGLE_SAFE_BROWSING_KEY=
# OPEN_PAGE_RANK_KEY=

# Fact Check Tools API — retrieve fact-check data from factcheck.org and others
# Required for integrating fact-check.org source reputation scoring
# Get key at: https://console.cloud.google.com → APIs & Services → Fact Check Tools API
GOOGLE_FACT_CHECK_API_KEY=
